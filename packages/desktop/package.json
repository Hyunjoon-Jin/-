{
  "name": "@soccer-tycoon/desktop",
  "version": "0.0.1",
  "private": true,
  "description": "축구 구단주 게임 Electron 데스크톱 셸 (SQLite 저장)",
  "main": "dist-main/main.js",
  "scripts": {
    "build:renderer": "node scripts/prepare-renderer.mjs",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.main.json --noEmit"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "build": {
    "appId": "com.soccertycoon.app",
    "productName": "Soccer Tycoon",
    "directories": { "output": "release" },
    "files": [
      "dist-main/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "linux": { "target": ["AppImage"], "category": "Game" },
    "win": { "target": ["nsis"] },
    "mac": { "target": ["dmg"], "category": "public.app-category.games" }
  }
}
